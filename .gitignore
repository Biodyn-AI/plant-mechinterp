# macOS AppleDouble metadata
._*
.DS_Store
Thumbs.db

# Large model files (downloadable via scripts/download_model.py or HuggingFace)
models/PlantCAD2-Small/pytorch_model.bin
models/PlantCAD2-Small/*.bin
models/**/*.bin
models/**/*.pt
models/**/*.safetensors
models/**/tokenizer*.json
models/**/*.model
models/plant-dnagemma-BPE/

# Raw genomic data (regeneratable via scripts/data/fetch_*.py)
data/real/raw/
data/test_sequences/

# Built derived datasets (regeneratable via scripts/data/build_*.py)
data/real/arareg/*.parquet
data/real/multispecies/*.parquet
data/real/splice/*.parquet
data/real/tfbs/*.parquet

# Model activation caches (regeneratable via analysis/probing/extract_activations.py)
data/real/activations/

# SAE weight files — too large for GitHub; upload to Zenodo instead
data/real/results/sae/*.pt

# Motif-score matrices (regeneratable via analysis/sae/precompute_motif_scores.py)
data/real/results/sae_enrichment/*.npy

# Full feature×motif enrichment tables — 29 MB each, regeneratable; keep only
# the distilled best-per-feature summaries in the repo.
data/real/results/sae_enrichment/*_feature_motif.csv
data/real/results/sae_enrichment/*_annotation.csv

# Logs
data/real/logs/

# Legacy large analysis artifacts
analysis/results/phase3/agront_comparison_results.pkl
analysis/results/*_hidden_states.npy
*.pkl

